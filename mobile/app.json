{
  "expo": {
    "name": "ISAFE",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/main.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/main.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/main.png",
        "backgroundColor": "#E6F4FE"
      },
      "package": "com.singurity.mobile"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-notifications"
    ],
    "extra": {
      "eas": {
        "projectId": "109d0d38-37f5-4464-8f30-5a7addb5f0ec"
      }
    },
    "owner": "mizureal"
  }
}
